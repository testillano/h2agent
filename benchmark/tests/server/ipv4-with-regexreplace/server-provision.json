[
  {
    "requestMethod": "POST",
    "requestUri": "/app/v1/benchmark/ipv4",
    "responseCode": 200,
    "responseBody": {
      "ipv4": ""
    },
    "responseHeaders": {
      "content-type": "application/json"
    },
    "transform": [
      {
        "source": "request.body./phone",
        "target": "var.digits",
        "filter": {
          "RegexReplace": {
            "rgx": "[0-9]*([0-9]{2})([0-9]{2})([0-9]{2})([0-9]{2})",
            "fmt": "$1.$2.$3.$4"
          }
        }
      },
      {
        "source": "var.digits",
        "target": "response.body.json.string./ipv4"
      }
    ]
  }
]
