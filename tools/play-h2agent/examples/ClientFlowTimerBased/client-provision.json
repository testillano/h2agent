[
  {
    "id":"myFlow",
    "endpoint":"myServer",
    "expectedResponseStatusCode": 200,
    "inState":"initial",
    "outState":"step2",
    "requestMethod":"GET",
    "requestHeaders":{"content-type":"application/json"},
    "transform":[
      {
        "source":"value./api/v1/hello/",
        "filter":{"Append":"@{sequence}"},
        "target":"request.uri"
      }
    ],
    "onResponseTransform":[
      {
        "source":"eraser",
        "target":"globalVar.helloResponse"
      },
      {
        "source":"response.body",
        "target":"globalVar.helloResponse"
      }
    ]
  },
  {
    "id":"myFlow",
    "endpoint":"myServer",
    "expectedResponseStatusCode": 200,
    "inState":"step2",
    "outState":"road-closed",
    "requestMethod":"POST",
    "requestHeaders":{"content-type":"application/json"},
    "transform":[
      {
        "source":"value./api/v1/goodbye/",
        "filter":{"Append":"@{sequence}"},
        "target":"request.uri"
      },
      {
        "source":"globalVar.helloResponse",
        "target":"request.body.json.jsonstring"
      }
    ]
  }
]
