{
  "requestMethod": "GET",
  "requestUri": "/app/v1/foo/bar/1",
  "responseCode": 200,
  "responseBody": {
    "foo": "bar-1"
  },
  "responseHeaders": {
    "content-type": "text/html",
    "x-version": "1.0.0"
  },
  "transform": [
    {
      "source": "value.255",
      "target": "response.body.json.string./hexLower",
      "filter": { "BaseConvert": { "in": 10, "out": 16 } }
    },
    {
      "source": "value.255",
      "target": "response.body.json.string./hexUpper",
      "filter": { "BaseConvert": { "in": 10, "out": 16, "capital": true } }
    }
  ]
}
